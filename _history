f (jumpBuffer > 0 && coyote > 0) {\n        player.vy = -150;\n        jumpBuffer = 0;\n        coyote = 0;\n    }\n});\n\n// jump input\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    jumpBuffer = 6;\n});\n\n// --- MODE SWITCHING ---\nlet mode = 0;\ncontroller.B.onEvent(ControllerButtonEvent.Pressed, function () {\n    mode = 1 - mode;\n    loadLevel(mode);\n});\n\n// --- LEVEL LOADING ---\nfunction loadLevel(m) {\n    if (m == 0) {\n        tiles.setCurrentTilemap(tilemap`level_day`);\n    } else {\n        tiles.setCurrentTilemap(tilemap`level_night`);\n    }\n\n    // reset player\n    tiles.placeOnTile(player, tiles.getTileLocation(1, 5));\n    player.vx = 0;\n    player.vy = 0;\n\n    // clear old sprites\n    sprites.allOfKind(SpriteKind.Enemy).forEach(s => s.destroy());\n    sprites.allOfKind(SpriteKind.Food).forEach(s => s.destroy());\n\n    spawnHazards(m);\n    spawnCoins(m);\n}\n\n// --- HAZARDS ---\nfunction spawnHazards(m) {\n    let positions = [];\n\n    if (m == 0) {\n        positions = [\n            tiles.getTileLocation(4, 5),\n            tiles.getTileLocation(7, 5)\n        ];\n    } else {\n        positions = [\n            tiles.getTileLocation(3, 4),\n            tiles.getTileLocation(6, 4)\n        ];\n    }\n\n    positions.forEach(loc => {\n        let spike = sprites.create(img`\n            . . 2 . .\n            . 2 2 2 .\n            2 2 2 2 2\n        `, SpriteKind.Enemy);\n        tiles.placeOnTile(spike, loc);\n    });\n}\n\n// --- COINS ---\nfunction spawnCoins(m) {\n    let positions = [];\n\n    if (m == 0) {\n        positions = [tiles.getTileLocation(8, 2)];\n    } else {\n        positions = [tiles.getTileLocation(2, 2)];\n    }\n\n    positions.forEach(loc => {\n        let coin = sprites.create(img`\n            . . 4 4 . .\n            . 4 2 2 4 .\n            4 2 4 4 2 4\n            4 2 4 4 2 4\n            . 4 2 2 4 .\n            . . 4 4 . .\n        `, SpriteKind.Food);\n        tiles.placeOnTile(coin, loc);\n    });\n}\n\n// --- COLLISIONS ---\nsprites.onOverlap(SpriteKind.Player, SpriteKind.Enemy, function () {\n    info.changeLifeBy(-1);\n    if (info.life() <= 0) {\n        game.over(false);\n    } else {\n        loadLevel(mode);\n    }\n});\n\nsprites.onOverlap(SpriteKind.Player, SpriteKind.Food, function (sprite, coin) {\n    coin.destroy();\n    info.changeScoreBy(1);\n});\n\n// --- HUD ---\ninfo.setLife(3);\ninfo.setScore(0);\n\n// --- TILEMAPS ---\n// Create these in the tilemap editor with the exact names below:\n\n// level_day:\n// ..........\n// ..........\n// ....###...\n// ..........\n// ..###.....\n// ..........\n// ##########\n\n// level_night:\n// ..........\n// ..###.....\n// ..........\n// ....###...\n// ..........\n// ..###.....\n// ##########\n\n// --- START ---\nloadLevel(mode);\n","README.md":" ","assets.json":"","pxt.json":"{\n    \"name\": \"platform-leo wu\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1781135490467,"editorVersion":"4.0.14","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable type=\"KIND_SpriteKind\" id=\"V~}qv-nY]go^++H89|*T\">Platform</variable><variable type=\"KIND_SpriteKind\" id=\":|u%MIcF+QtK378(idpY\">Player</variable><variable type=\"KIND_SpriteKind\" id=\"Hw^EdejczZX6q^~}`~oI\">Projectile</variable><variable type=\"KIND_SpriteKind\" id=\"K9v6DT}7W+UJCqtlwPyu\">Food</variable><variable type=\"KIND_SpriteKind\" id=\"bZ9C_}OoCUNoZLlm,2xO\">Enemy</variable><variable id=\"LEcboP9/xk?i?wh}rsi#\">p</variable><variable id=\"x+Ofr)c$__Xj3d|Xy8De\">grounded</variable><variable id=\"*_%]w:,M!h|]K;Jd|pg?\">player</variable><variable id=\"T48w.CbgsX}spX*H2_00\">mySprite</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"><statement 