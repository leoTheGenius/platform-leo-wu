form thingy\", \"try it\")\ngame.splash(\"basically left/right to \", \"move left and right and a to jump, \")\ngame.splash(\"and there is portal thing \", \"if you cross it then you change into a different gamemode wheere a switches your gravity\")\ngame.splash(\"if you touch spike reset\", \"also i know this is heavily based on geometry dash\")\ngame.splash(\"just one more thing\", \"this is not using corgio as used in simpleextensions\")\nlet starttime = game.runtime()\nlet grounded = false\nlet touching = false\nlet player1: Sprite = null\nlet p: Sprite = null\nlet s: Sprite = null\nlevel = 1\nmode = \"normal\"\nportalready = true\nplayer1 = sprites.create(img`\n    . . f f f . . \n    . f 1 1 1 f . \n    f 1 1 1 1 1 f \n    f 1 f 1 f 1 f \n    f 1 1 1 1 1 f \n    . f 1 1 1 f . \n    . . f f f . . \n    `, SpriteKind.Player)\ncontroller.moveSprite(player1, 80, 0)\nplayer1.ay = 300\nplayer1.setStayInScreen(true)\nloadlevel(level)\ngame.onUpdate(function () {\n    info.setScore((game.runtime()-starttime)/1000)\n    grounded = false\n    sprites.allOfKind(SpriteKind.platform).forEach(p => {\n        let top =\n            player1.vy >= 0 &&\n            player1.bottom >= p.top &&\n            player1.bottom <= p.top + 10 &&\n            player1.right > p.left &&\n            player1.left < p.right\n\n        if (top) {\n            player1.bottom = p.top\n            player1.vy = 0\n            grounded = true\n        }\n\n        let bottom =\n            player1.vy < 0 &&\n            player1.top <= p.bottom &&\n            player1.top >= p.bottom - 10 &&\n            player1.right > p.left &&\n            player1.left < p.right\n\n        if (bottom) {\n            player1.top = p.bottom\n            player1.vy = 0\n        }\n    })\nif (player1.bottom > scene.screenHeight()) {\n        player1.bottom = scene.screenHeight()\n        player1.vy = 0\n        grounded = true\n    }\n    if (player1.top < 0) {\n        player1.top = 0\n        player1.vy = 0\n    }\n    if (player1.left < 0) {\n        player1.left = 0\n        player1.vx = 0\n    }\n    if (player1.right > scene.screenWidth()) {\n        player1.right = scene.screenWidth()\n        player1.vx = 0\n    }\n})\ngame.onUpdate(function () {\n    touching = false\n    sprites.allOfKind(SpriteKind.portal).forEach(p => {\n        if (player1.overlapsWith(p)) touching = true\n    })\nif (!(touching)) {\n        portalready = true\n    }\n})\n","README.md":" ","assets.json":"","tilemap.g.jres":"{\n    \"transparency16\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"tilemapTile\": true\n    },\n    \"level5\": {\n        \"id\": \"level5\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\",\n            \"sprites.dungeon.darkGroundNorthWest1\"\n        ],\n        \"displayName\": \"level5\"\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myTiles\"\n    }\n}","tilemap.g.ts":"","pxt.json":"{\n    \"name\": \"platform-leo wu\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"tilemap.g.jres\",\n        \"tilemap.g.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1781189787585,"editorVersion":"4.0.14","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable type=\"KIND_SpriteKind\" id=\"@.{x6thCK;/OZj3!F]lC\">platform</variable><variable type=\"KIND_SpriteKind\" id=\"4Qqu(7+:@H}f!-9qD_[u\">spike</variable><variable type=\"KIND_SpriteKind\" id=\"Z;8~F=.*Spz